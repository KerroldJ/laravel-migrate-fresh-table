# Copy to .env and adjust to your local database to run the test suite against
# a real driver. With no .env (or DB_CONNECTION unset) the suite uses an
# in-memory SQLite database.
#
# DB_CONNECTION accepts: sqlite | mysql | mariadb | pgsql | sqlsrv
# (postgres/postgresql and mssql/sqlserver are accepted as aliases).

DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=laravel_test
DB_USERNAME=postgres
DB_PASSWORD=

# Notes:
# - pgsql: the suite isolates its two connections using schemas (mft_testing,
#   mft_secondary) inside DB_DATABASE, which it creates/drops automatically.
# - mysql/mariadb/sqlsrv: it uses two databases, mft_testing and mft_secondary,
#   which must already exist (e.g. CREATE DATABASE mft_testing;).
